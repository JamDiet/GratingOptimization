#!/bin/bash
#SBATCH --time=5:00:00
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=40
#SBATCH --account=PAS1730
#SBATCH --exclusive
#SBATCH --output=../logs/proto_%j.out
#SBATCH --error=../logs/proto_%j.err

# Submit with the Prototype directory as your working directory:
#   cd experiments/<name>/Prototype && sbatch sub_test.job default.yml
# --output/--error resolve relative to that CWD, landing one level up in the
# shared experiment-level logs/ folder.

set -euo pipefail

if [ -z "${SLURM_SUBMIT_DIR:-}" ]; then
    echo "ERROR: SLURM_SUBMIT_DIR is not set -- submit with sbatch from experiments/<name>/Prototype/." >&2
    exit 1
fi

if [ $# -lt 1 ]; then
    echo "Usage: sbatch sub_test.job <config_name.yml>" >&2
    exit 1
fi

PROTOTYPE_DIR="$SLURM_SUBMIT_DIR"
REPO_ROOT="$(cd "$PROTOTYPE_DIR/../../.." && pwd)"

module reset
module load python/3.12
module load matlab/r2024a

source "$REPO_ROOT/venv/bin/activate"
export PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"

python "$PROTOTYPE_DIR/main.py" "$1"
